{
  "name": "tech-deels",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*", "services/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "test": "bun run --cwd apps/web test",
    "lint": "bun run --cwd apps/web lint",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:push": "bun run --cwd packages/db push",
    "db:seed": "bun run --cwd packages/db seed",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down"
  }
}
