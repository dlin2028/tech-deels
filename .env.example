# Environment variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://techdeels:techdeels@localhost:5432/techdeels

# Redis (for future use)
REDIS_URL=redis://localhost:6379

# Application
NODE_ENV=development
PORT=3000
ORIGIN=http://localhost:3000

# Auth
# No additional secrets needed - Lucia uses session cookies

# Search (optional - for search-sync service)
# MEILI_HOST=http://localhost:7700
# MEILI_KEY=your-master-key-here

# Email (optional - for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@techdeels.com
